{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Regex Batch Renamer",
  "version": "0.5.2",
  "identifier": "com.junyou.regexbatchrenamer",
  "build": {
    "beforeDevCommand": "pnpm vite --config vite.config.tauri.mts",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm vite build --config vite.config.tauri.mts",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Regex Batch Renamer",
        "width": 1200,
        "height": 800,
        "dragDropEnabled": true
      }
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "",
      "endpoints": []
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": false,
    "icon": [
      "icons/icon.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "resources": [
      "../public/icon.png",
      "../public/icon.ico",
      "../public/icon-mac.png"
    ]
  }
}
